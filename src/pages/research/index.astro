---
import Base from '../../layouts/Base.astro';
import EntryCard from '../../components/EntryCard.astro';
import { getCollection } from 'astro:content';

const collection = await getCollection('research');
const entries = collection[0]?.data?.entries ?? [];
const sorted = [...entries].sort((a: any, b: any) => (b.year ?? 0) - (a.year ?? 0));
---

<Base title="研究资源" description="抽动症研究资源和英文文献中文桥接">
  <h1 class="text-xl font-bold text-gray-900 mb-2">研究资源</h1>
  <p class="text-sm text-gray-600 mb-4">国外高质量研究资源，部分有中文版本可读</p>

  <div class="space-y-3">
    {sorted.map((entry: any) => (
      <EntryCard
        title={entry.title}
        subtitle={entry.description}
        url={entry.url}
        trustLevel={entry.trust_level}
        lang={entry.lang}
        organization={entry.organization}
        year={entry.year}
        hasChineseVersion={entry.has_chinese_version}
        chineseVersionUrl={entry.chinese_version_url}
      />
    ))}
  </div>
</Base>
