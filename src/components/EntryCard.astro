---
import TrustBadge from './TrustBadge.astro';
import LangBadge from './LangBadge.astro';

export type Props = {
  title: string;
  subtitle?: string;
  url: string;
  trustLevel: string;
  lang?: string;
  organization?: string;
  year?: number;
  tags?: string[];
  hasChineseVersion?: boolean;
  chineseVersionUrl?: string;
  caution?: string;
};

const { title, subtitle, url, trustLevel, lang, organization, year, tags, hasChineseVersion, chineseVersionUrl, caution } = Astro.props;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="block p-4 rounded-xl border border-gray-200 hover:border-indigo-300 card-hover bg-white group">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <h3 class="text-sm font-semibold text-gray-900 group-hover:text-indigo-600 truncate">{title}</h3>
      {organization && <p class="text-xs text-gray-500 mt-0.5">{organization}{year ? ` · ${year}` : ''}</p>}
      {subtitle && <p class="text-xs text-gray-600 mt-1 line-clamp-2">{subtitle}</p>}
      {tags && tags.length > 0 && (
        <div class="flex gap-1 mt-1.5 flex-wrap">
          {tags.map((tag) => <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">{tag}</span>)}
        </div>
      )}
      {hasChineseVersion && (
        <div class="mt-1.5">
          <span class="inline-flex items-center text-xs text-green-600 gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586L7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            中文版可读
          </span>
          {chineseVersionUrl && <a href={chineseVersionUrl} target="_blank" rel="noopener noreferrer" class="text-xs text-indigo-500 ml-1 hover:underline">查看</a>}
        </div>
      )}
    </div>
    <div class="flex items-center gap-1.5 shrink-0">
      <TrustBadge level={trustLevel} />
      {lang && <LangBadge lang={lang} />}
    </div>
  </div>
  {caution && (
    <div class="mt-2 px-3 py-1.5 rounded-lg bg-orange-50 text-orange-700 text-xs border border-orange-100">
      {caution}
    </div>
  )}
  <div class="mt-2 flex items-center gap-1 text-xs text-gray-400 group-hover:text-indigo-400 transition-colors">
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
    <span>访问来源</span>
  </div>
</a>
