---
export type Props = { level: string };

const config: Record<string, { color: string; label: string; bg: string }> = {
  official: { color: 'text-green-700', label: '官方权威', bg: 'bg-green-50' },
  expert: { color: 'text-blue-700', label: '专家观点', bg: 'bg-blue-50' },
  verified_org: { color: 'text-amber-700', label: '认证组织', bg: 'bg-amber-50' },
  community: { color: 'text-orange-700', label: '病友经验', bg: 'bg-orange-50' },
  unverified: { color: 'text-red-700', label: '待验证', bg: 'bg-red-50' },
};

const { level } = Astro.props;
const c = config[level] ?? config.unverified;
---

<span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${c.bg} ${c.color}`}>
  {c.label}
</span>
